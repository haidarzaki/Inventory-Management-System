# ─── Environment variables untuk Docker deployment ────────────────────────────
# Copy file ini jadi .env, lalu isi sesuai kebutuhan

# Password database PostgreSQL
DB_PASSWORD=ganti_password_db_kamu

# Secret JWT (buat string acak yang panjang)
JWT_SECRET=ganti_dengan_string_acak_yang_sangat_panjang_dan_susah_ditebak
