# Koneksi ke database PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/assettrace?schema=public"

# Secret untuk menandatangani JWT - GANTI dengan string acak yang panjang di production
JWT_SECRET="ganti-dengan-secret-yang-acak-dan-panjang"
JWT_EXPIRES_IN="7d"

# Port server API
PORT=3000

# Domain frontend yang diizinkan mengakses API (pisahkan dengan koma jika lebih dari satu)
CORS_ORIGIN="http://localhost:5173"
